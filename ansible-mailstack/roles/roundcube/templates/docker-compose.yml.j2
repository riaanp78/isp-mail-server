services:
  roundcube:
    image: "{{ roundcube_docker_image }}"
    container_name: roundcube
    restart: unless-stopped
    environment:
      ROUNDCUBEMAIL_DB_TYPE: "{{ roundcube_db_type }}"
      ROUNDCUBEMAIL_DB_HOST: "{{ mysql_host }}"
      ROUNDCUBEMAIL_DB_USER: "{{ roundcube_db_user }}"
      ROUNDCUBEMAIL_DB_PASSWORD: "{{ roundcube_db_password }}"
      ROUNDCUBEMAIL_DB_NAME: "{{ roundcube_db_name }}"
      ROUNDCUBEMAIL_DES_KEY: "{{ roundcube_des_key }}"
      ROUNDCUBEMAIL_DEFAULT_HOST: "ssl://{{ roundcube_imap_cluster | first }}"
      ROUNDCUBEMAIL_DEFAULT_PORT: "{{ roundcube_imap_port }}"
      ROUNDCUBEMAIL_SMTP_SERVER: "ssl://{{ roundcube_smtp_cluster | first }}"
      ROUNDCUBEMAIL_SMTP_PORT: "{{ roundcube_smtp_port }}"
      ROUNDCUBEMAIL_PLUGINS: "{{ roundcube_plugins | join(',') }}"
      ROUNDCUBEMAIL_SKIN: "{{ roundcube_skin | default('elastic') }}"
    volumes:
      - /opt/roundcube/data:/var/www/html/temp
      - /opt/roundcube/logs:/var/www/html/logs
      - /opt/roundcube/config.inc.php:/var/www/html/config/config.inc.php
    networks:
      - roundcube_net
  roundcube-nginx:
    image: nginx:alpine
    container_name: roundcube-nginx
    restart: always
    depends_on:
      - roundcube
    ports:
      - "{{ roundcube_expose_port }}:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - roundcube_net
networks:
  roundcube_net:
    driver: bridge