services:
  roundcube:
    image: "{{ roundcube_docker_image }}"
    container_name: roundcube
    restart: unless-stopped
    environment:
      # Only DB env vars needed — everything else is in mounted config.inc.php.
      # Passing IMAP/SMTP env vars here would conflict with the mounted config
      # because the Docker entrypoint rewrites config.inc.php from env vars
      # BEFORE the volume mount is applied, causing the env var values to win.
      ROUNDCUBEMAIL_DB_TYPE:     "{{ roundcube_db_type }}"
      ROUNDCUBEMAIL_DB_HOST:     "{{ mysql_host }}"
      ROUNDCUBEMAIL_DB_USER:     "{{ roundcube_db_user }}"
      ROUNDCUBEMAIL_DB_PASSWORD: "{{ roundcube_db_password }}"
      ROUNDCUBEMAIL_DB_NAME:     "{{ roundcube_db_name }}"
      ROUNDCUBEMAIL_DES_KEY:     "{{ roundcube_des_key }}"
      # Disable the entrypoint config generator so our mounted file wins
      ROUNDCUBEMAIL_SKIP_INITDB: "false"
    volumes:
      - /opt/roundcube/data:/var/www/html/temp
      - /opt/roundcube/logs:/var/www/html/logs
      # Mount our config as read-only — this is the sole source of truth
      - /opt/roundcube/config.inc.php:/var/www/html/config/config.inc.php:ro
    networks:
      - roundcube_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  roundcube-nginx:
    image: nginx:alpine
    container_name: roundcube-nginx
    restart: unless-stopped
    depends_on:
      - roundcube
    ports:
      - "{{ roundcube_expose_port }}:80"
    volumes:
      - /opt/roundcube/nginx.conf:/etc/nginx/conf.d/default.conf
    networks:
      - roundcube_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  roundcube_net:
    driver: bridge
