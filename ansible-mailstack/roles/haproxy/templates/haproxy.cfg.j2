# HAProxy 2.8 configuration for MailStack
# Managed by Ansible - DO NOT EDIT MANUALLY
# Generated: {{ ansible_date_time.iso8601 }}

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    # Default SSL material locations
    ca-base /etc/ssl/certs
    crt-base /etc/ssl/private

    # Default ciphers (TLS 1.2 and 1.3 only)
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets

    # Disable server-side SSL verification globally for self-signed certs.
    # Individual backends that need verification can override with 'verify required'.
    ssl-server-verify none

    # Performance tuning
    nbthread {{ ansible_processor_cores | default(2) }}
    tune.ssl.default-dh-param 2048
    tune.bufsize 16384
    tune.maxrewrite 8192

defaults
    log global
    mode tcp
    option tcplog
    option dontlognull
    option redispatch
    retries 3
    maxconn {{ haproxy_backend_maxconn | default(4096) }}
    timeout connect {{ haproxy_timeout_connect | default('10s') }}
    timeout client  {{ haproxy_timeout_client  | default('30s') }}
    timeout server  {{ haproxy_timeout_server  | default('30s') }}
    timeout queue   {{ haproxy_timeout_queue   | default('30s') }}
    timeout tunnel  {{ haproxy_timeout_tunnel  | default('1h')  }}
    # http-request timeout only applies in http mode — set per-frontend below
    # (putting it in tcp defaults causes a warning on HAProxy 2.8)

# ============================================
# STATISTICS PAGE (LOCALHOST ONLY)
# ============================================

listen stats
    bind 127.0.0.1:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats realm HAProxy\ Statistics
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats admin if TRUE
    http-request add-header X-Frame-Options DENY
    http-request add-header X-Content-Type-Options nosniff
    http-request add-header Cache-Control no-cache

# ============================================
# ROUNDCUBE WEBMAIL (HTTP / HTTPS)
# HAProxy terminates SSL, forwards plain HTTP to Roundcube containers.
# Sticky sessions via cookie so a user always hits the same Roundcube node.
# ============================================

frontend webmail_http
    bind :80
    mode http
    option httplog
    timeout http-request 10s
    capture request header Host len 32
    capture request header X-Forwarded-For len 15
    default_backend roundcube_backend

frontend webmail_https
    bind :443 ssl crt {{ haproxy_ssl_cert_path }} alpn h2,http/1.1
    mode http
    option httplog
    timeout http-request 10s
    http-request set-header X-Forwarded-Proto https
    capture request header Host len 32
    capture request header X-Forwarded-For len 15
    default_backend roundcube_backend

backend roundcube_backend
    mode http
    balance roundrobin
    option httpchk
    http-check send meth HEAD uri /health-check ver HTTP/1.1 hdr Host localhost
    http-check expect status 200
    cookie MAILSTACK_RC insert indirect nocache
{% for host in groups['roundcube_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:80 cookie {{ host }} check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }} maxconn {{ haproxy_maxconn_per_ip | default(200) }}
{% endfor %}

# ============================================
# POSTFIX SMTP (PORT 25) — plain, no SSL
# smtpchk sends EHLO and expects 250 — correct for port 25.
# ============================================

frontend smtp
    bind :25
    mode tcp
    option tcplog
    default_backend postfix_smtp_backend

backend postfix_smtp_backend
    mode tcp
    balance roundrobin
    option smtpchk
{% for host in groups['postfix_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:25 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }} maxconn {{ haproxy_maxconn_per_ip | default(200) }}
{% endfor %}

# ============================================
# POSTFIX SMTPS (PORT 465) — implicit SSL
# HAProxy terminates SSL on :465, then forwards plain SMTP to backend:465.
# Health check: open SSL connection to backend, expect SMTP 220 banner.
# Backend speaks SSL so the check probe must also use SSL (verify none = self-signed).
# ============================================

frontend smtps
    bind :465 ssl crt {{ haproxy_ssl_cert_path }}
    mode tcp
    option tcplog
    default_backend postfix_smtps_backend

backend postfix_smtps_backend
    mode tcp
    balance roundrobin
    option tcp-check
    tcp-check connect ssl
    tcp-check expect string "220"
{% for host in groups['postfix_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:465 ssl verify none check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }} maxconn {{ haproxy_maxconn_per_ip | default(200) }}
{% endfor %}

# ============================================
# POSTFIX SUBMISSION (PORT 587) — STARTTLS
# Plain TCP connect, Postfix sends 220 banner immediately before STARTTLS.
# smtpchk (sends EHLO, expects 250) is correct here — no SSL on initial connect.
# ============================================

frontend submission
    bind :587
    mode tcp
    option tcplog
    default_backend postfix_submission_backend

backend postfix_submission_backend
    mode tcp
    balance roundrobin
    option smtpchk
{% for host in groups['postfix_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:587 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }} maxconn {{ haproxy_maxconn_per_ip | default(200) }}
{% endfor %}

# ============================================
# DOVECOT IMAP (PORT 143) — plain STARTTLS
# Dovecot sends "* OK" banner on plain TCP connect before STARTTLS negotiation.
# balance source = same user always hits the same Dovecot node (index consistency).
# ============================================

frontend imap
    bind :143
    mode tcp
    option tcplog
    default_backend dovecot_imap_backend

backend dovecot_imap_backend
    mode tcp
    balance source
    option tcp-check
    tcp-check expect string "* OK"
{% for host in groups['dovecot_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:143 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }} maxconn {{ haproxy_maxconn_per_ip | default(200) }}
{% endfor %}

# ============================================
# DOVECOT IMAPS (PORT 993) — implicit SSL
# HAProxy terminates SSL on :993, forwards plain IMAP to backend:993.
# Health check connects with SSL to backend, expects "* OK" IMAP banner.
# balance source = index consistency per user across Dovecot nodes.
# ============================================

frontend imaps
    bind :993 ssl crt {{ haproxy_ssl_cert_path }}
    mode tcp
    option tcplog
    default_backend dovecot_imaps_backend

backend dovecot_imaps_backend
    mode tcp
    balance source
    option tcp-check
    tcp-check connect ssl
    tcp-check expect string "* OK"
{% for host in groups['dovecot_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:993 ssl verify none check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }} maxconn {{ haproxy_maxconn_per_ip | default(200) }}
{% endfor %}

# ============================================
# PROMETHEUS MANAGESIEVE (PORT 8405) — plain TCP
# ============================================
frontend prometheus
  bind *:8405
  mode http
  http-request use-service prometheus-exporter if { path /metrics }
  no log

# ============================================
# DOVECOT MANAGESIEVE (PORT 4190) — plain TCP
# Dovecot sends a capability string containing IMPLEMENTATION on connect.
# No SSL on this port — plain TCP passthrough.
# balance source = sieve rules are stored per-user on a specific Dovecot node.
# ============================================

frontend managesieve
    bind :4190
    mode tcp
    option tcplog
    default_backend dovecot_managesieve_backend

backend dovecot_managesieve_backend
    mode tcp
    balance source
    option tcp-check
    tcp-check expect string IMPLEMENTATION
{% for host in groups['dovecot_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:4190 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }}
{% endfor %}

# ============================================
# INTERNAL SERVICES
# All bound to 127.0.0.1 — reachable only from haproxy01 itself.
# Postfix and other local services use these to reach backend clusters.
# ============================================

# DOVECOT LMTP (PORT 24)
# Postfix delivers mail to Dovecot via LMTP through this listener.
listen dovecot_lmtp
    bind 127.0.0.1:24
    mode tcp
    option tcplog
    balance roundrobin
{% for host in groups['dovecot_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:24 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }}
{% endfor %}

# DOVECOT SASL (PORT 12345)
# Postfix uses this for SMTP AUTH delegation to Dovecot.
listen dovecot_sasl
    bind 127.0.0.1:12345
    mode tcp
    option tcplog
    balance roundrobin
{% for host in groups['dovecot_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:12345 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }}
{% endfor %}

# RSPAMD (PORT 11334)
listen rspamd
    bind 127.0.0.1:11334
    mode tcp
    option tcplog
    balance roundrobin
{% for host in groups['rspamd_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:11334 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }}
{% endfor %}

# CLAMAV (PORT 3310)
listen clamav
    bind 127.0.0.1:3310
    mode tcp
    option tcplog
    balance roundrobin
{% for host in groups['clamav_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:3310 check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }}
{% endfor %}
