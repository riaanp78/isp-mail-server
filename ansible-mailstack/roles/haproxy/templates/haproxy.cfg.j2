# HAProxy configuration for MailStack
# Managed by Ansible - DO NOT EDIT MANUALLY
# Generated: {{ ansible_date_time.iso8601 }}

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    # Default SSL material locations
    ca-base /etc/ssl/certs
    crt-base /etc/ssl/private

    # Default ciphers (TLS 1.2 and 1.3 only)
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets

    # Performance tuning
    nbthread {{ ansible_processor_cores | default(2) }}
    tune.ssl.default-dh-param 2048
    tune.bufsize 16384
    tune.maxrewrite 8192

defaults
    log global
    mode tcp
    option tcplog
    option dontlognull
    option redispatch
    retries 3
    maxconn {{ haproxy_backend_maxconn | default(4096) }}
    timeout connect {{ haproxy_timeout_connect | default('10s') }}
    timeout client {{ haproxy_timeout_client | default('30s') }}
    timeout server {{ haproxy_timeout_server | default('30s') }}
    timeout queue {{ haproxy_timeout_queue | default('30s') }}
    timeout tunnel {{ haproxy_timeout_tunnel | default('1h') }}
    timeout http-request 10s

# ============================================
# STATISTICS PAGE (LOCALHOST ONLY - SECURE)
# ============================================

listen stats
    bind 127.0.0.1:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats realm HAProxy\ Statistics
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats admin if TRUE
    http-request add-header X-Frame-Options DENY
    http-request add-header X-Content-Type-Options nosniff
    http-request add-header Cache-Control no-cache

# ============================================
# ROUNDCUBE WEBMAIL (HTTP/HTTPS)
# ============================================

frontend webmail_http
    bind :80
    mode http
    option httplog
    capture request header Host len 32
    capture request header X-Forwarded-For len 15
    default_backend roundcube_backend

frontend webmail_https
    bind :443 ssl crt {{ haproxy_ssl_cert_path }} alpn h2,http/1.1
    mode http
    option httplog
    http-request set-header X-Forwarded-Proto https
    capture request header Host len 32
    capture request header X-Forwarded-For len 15
    default_backend roundcube_backend

backend roundcube_backend
    mode http
    balance roundrobin
    option httpchk
    http-check send meth HEAD uri / ver HTTP/1.1 hdr Host localhost
    http-check expect status 200
    cookie MAILSTACK_RC insert indirect nocache
{% for host in groups['roundcube_servers'] | default([]) %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:80 cookie {{ host }} check inter {{ haproxy_health_check_interval | default('5s') }} fall {{ haproxy_health_check_fall | default(3) }} rise {{ haproxy_health_check_rise | default(2) }} maxconn {{ haproxy_maxconn_per_ip | default(200) }}
{% endfor %}

