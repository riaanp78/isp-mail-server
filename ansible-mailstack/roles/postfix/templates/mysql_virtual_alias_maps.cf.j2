# MySQL virtual alias map
# Queries the postfix_aliases view which UNION's:
#   - explicit aliases from the alias table
#   - mailbox self-delivery entries (username -> username)
# This means every active mailbox is also implicitly a valid recipient.
user     = {{ db_user }}
password = {{ db_password }}
hosts    = {{ db_host }}
dbname   = {{ db_name }}
query    = SELECT goto FROM postfix_aliases WHERE address='%s'

