# MySQL virtual mailbox map
# Queries the postfix_mailboxes view.
# Returns: {domain}/{local_part}/Maildir/
# This tells Postfix the mailbox exists; actual delivery is via LMTP.
user     = {{ db_user }}
password = {{ db_password }}
hosts    = {{ db_host }}
dbname   = {{ db_name }}
query    = SELECT maildir FROM postfix_mailboxes WHERE username='%s'

