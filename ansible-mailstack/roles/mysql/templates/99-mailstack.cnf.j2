# Mailstack MySQL Configuration
[mysqld]

# Performance tuning for mail server workload
innodb_buffer_pool_size = 2G
innodb_log_file_size = 512M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# Connection settings
max_connections = 500
connect_timeout = 10
wait_timeout = 28800
interactive_timeout = 28800

# Query cache (disabled in MySQL 8.0, using buffer pool)
# Character set
character_set_server = utf8mb4
collation_server = utf8mb4_unicode_ci

# Log slow queries
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2

# Binary logging for replication (optional)
log_bin = /var/log/mysql/mysql-bin.log
binlog_format = ROW
expire_logs_days = 7

# Mail-specific settings
max_allowed_packet = 64M
sort_buffer_size = 2M
read_buffer_size = 2M