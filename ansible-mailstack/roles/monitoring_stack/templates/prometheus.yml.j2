# Managed by Ansible - DO NOT EDIT MANUALLY
# Generated: {{ ansible_date_time.iso8601 }}

global:
  scrape_interval: 15s
  evaluation_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets: []

rule_files: []

scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Node Exporters (system metrics for all mail servers)
  - job_name: 'node'
    static_configs:
      - targets:
{% for host in groups['monitoring_targets'] | default([]) %}
{% set host_ip = hostvars[host]['ansible_host'] if 'ansible_host' in hostvars[host] else None %}
{% if host_ip and host_ip != 'unknown' %}
        - '{{ host_ip }}:9100'
{% endif %}
{% endfor %}

# DOVECOT 

{% if dovecot_exporter | default(false) %}
  # Dovecot metrics (built-in OpenMetrics)
  - job_name: 'dovecot'
    static_configs:
      - targets:
{% for host in groups['dovecot_servers'] %}
{% set host_ip = hostvars[host]['ansible_host'] if 'ansible_host' in hostvars[host] else None %}
{% if host_ip and host_ip != 'unknown' %}
        - '{{ host_ip }}:9900'
{% endif %}
{% endfor %}
{% endif %}


