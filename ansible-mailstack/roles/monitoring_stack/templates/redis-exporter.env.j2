# Managed by Ansible - Redis Exporter Configuration for Valkey

# Valkey/Redis connection address
REDIS_ADDR={{ valkey_host }}:{{ valkey_port }}

# Valkey/Redis password (if set)
{% if valkey_password | length > 0 %}
REDIS_PASSWORD={{ valkey_password }}
{% endif %}

# Exporter listen address
REDIS_EXPORTER_WEB_LISTEN_ADDRESS=:9121

# Additional options
# REDIS_EXPORTER_LOG_FORMAT=txt
# REDIS_EXPORTER_DEBUG=false

