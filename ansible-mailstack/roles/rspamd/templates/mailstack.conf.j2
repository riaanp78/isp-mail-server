# MailStack Configuration for Rspamd Server
# Generated by Ansible - DO NOT EDIT MANUALLY

[mailstack]
mail_domain = {{ mail_domain }}
vmail_home = {{ vmail_home }}

[database]
host = {{ mysql_host }}
port = {{ mysql_port }}
name = {{ db_name }}
user = {{ db_user }}
password = {{ db_password }}

[rspamd]
host = {{ rspamd_host }}
controller_port = {{ rspamd_controller_port }}
milter_port = {{ rspamd_milter_port }}
proxy_port = {{ rspamd_proxy_port }}

[valkey]
host = {{ valkey_host }}
port = {{ valkey_port }}
password = {{ valkey_password }}

[nfs]
host = {{ nfs_host }}
export = {{ nfs_export }}
mount_options = {{ nfs_mount_options }}

[networks]
internal_networks = {{ internal_networks | join(',') }}