{
  "log-driver": "{{ docker_daemon_config['log-driver'] }}",
  "log-opts": {
    "max-size": "{{ docker_daemon_config['log-opts']['max-size'] }}",
    "max-file": "{{ docker_daemon_config['log-opts']['max-file'] }}"
  },
  "storage-driver": "{{ docker_daemon_config['storage-driver'] }}",
  "ip-forward": {{ docker_daemon_config['ip-forward'] | lower }},
  "iptables": {{ docker_daemon_config['iptables'] | lower }},
  "ip-masq": {{ docker_daemon_config['ip-masq'] | lower }},
  "userland-proxy": {{ docker_daemon_config['userland-proxy'] | lower }},
  "experimental": {{ docker_experimental | lower }},
  "live-restore": true
  {% if docker_registry_mirrors | length > 0 %},
  "registry-mirrors": {{ docker_registry_mirrors | to_json }}
  {% endif %}
}