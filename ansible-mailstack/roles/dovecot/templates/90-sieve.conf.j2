# ============================================================
# Dovecot 2.4 Sieve Configuration
# Managed by Ansible
# ============================================================

protocol lda {
  mail_plugins {
    sieve = yes
  }
}

protocol lmtp {
  mail_plugins {
    sieve = yes
  }
}

# Personal sieve scripts live under the user's home dir on NFS:
# /var/vmail/{domain}/{local_part}/sieve/
# ~ resolves to home from userdb (CONCAT('/var/vmail/', domain, '/', local_part))
sieve_script personal {
  driver      = file
  path        = ~/sieve
  active_path = ~/.dovecot.sieve
}

# Global default: applied when the user has no active personal script
sieve_script default {
  type   = default
  name   = default
  driver = file
  path   = /etc/dovecot/sieve/default.sieve
}

sieve_max_script_size = {{ dovecot_sieve_max_script_size | default('1M') }}
sieve_max_actions     = {{ dovecot_sieve_max_actions | default(32) }}

protocol managesieve {
  managesieve_notify_capability = mailto
}
