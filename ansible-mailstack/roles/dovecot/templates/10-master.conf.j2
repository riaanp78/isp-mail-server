# ============================================================
# Dovecot 2.4 Service Configuration
# Managed by Ansible
# ============================================================

service imap-login {
  inet_listener imap {
    port = 143
  }
  inet_listener imaps {
    port = 993
    ssl  = yes
  }
}

service pop3-login {
  inet_listener pop3 {
    port = 110
  }
  inet_listener pop3s {
    port = 995
    ssl  = yes
  }
}

service managesieve-login {
  inet_listener sieve {
    port = {{ dovecot_managesieve_port | default(4190) }}
  }
}

service lmtp {
  # Do NOT set user = vmail here; causes anvil permission errors in 2.4
  inet_listener lmtp {
    port = {{ dovecot_lmtp_port | default(24) }}
  }
}

service auth {
  # SASL for Postfix — bind to Postfix server IP only, not 0.0.0.0
  # If Postfix is on the same host, use a Unix socket instead (safer):
  #   unix_listener /var/spool/postfix/private/auth {
  #     mode  = 0660
  #     user  = postfix
  #     group = postfix
  #   }
  inet_listener auth {
    listen = {{ postfix_ip | default('0.0.0.0') }}
    port   = {{ dovecot_sasl_port | default(12345) }}
  }

  unix_listener auth-userdb {
    mode  = 0600
    user  = vmail
    group = vmail
  }
}

service anvil {
  unix_listener anvil-auth-penalty {
    user  = vmail
    group = vmail
    mode  = 0660
  }
  unix_listener anvil {
    user  = vmail
    group = vmail
    mode  = 0660
  }
}

service stats {
  unix_listener stats-writer {
    user  = vmail
    group = vmail
    mode  = 0660
  }
}
