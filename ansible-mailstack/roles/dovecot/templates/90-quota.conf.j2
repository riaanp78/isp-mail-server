# ============================================================
# Dovecot 2.4 Quota Configuration
# Managed by Ansible
#
# Strategy:
#   - 'count' driver enforces limits using index metadata (no vsize scan)
#   - Per-user limit comes from userdb quota_storage_size field
#     (returned by the SQL userdb query from mailbox.quota column)
#   - 90-quota.conf sets the *default* fallback limit only;
#     per-user values from userdb override it automatically
# ============================================================

mail_plugins {
  quota = yes
}

protocol imap {
  mail_plugins {
    imap_quota = yes
  }
}

# Shown to the sending MTA when quota is exceeded
quota_exceeded_message = User %{user} has exhausted allowed storage space.

# Required by count driver
mailbox_list_index = yes

# Avoid blocking delivery while vsize is being calculated
protocol !indexer-worker {
  mail_vsize_bg_after_count = 100
}

# Default quota root — applies when userdb returns no quota_storage_size
# (i.e. quota = 0 / NULL in the DB, meaning unlimited, so this fallback
# only fires for accounts that somehow have no quota row at all)
quota "User quota" {
  quota_driver          = count
  quota_storage_size    = {{ dovecot_default_quota | default('1G') }}
}
