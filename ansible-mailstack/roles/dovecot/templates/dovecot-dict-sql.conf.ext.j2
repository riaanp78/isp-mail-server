## Dictionary SQL configuration (Native 2.4.3)

# The 'mysql:' prefix ensures the dictionary service loads the correct library
connect = mysql:host={{ db_host }} dbname={{ db_name }} user={{ db_user }} password={{ db_password }} port={{ db_port | default(3306) }}

map {
  pattern = priv/quota/storage
  table = quota
  username_field = username
  value_field = bytes
}

map {
  pattern = priv/quota/messages
  table = quota
  username_field = username
  value_field = count
}