# ============================================================
# Dovecot 2.4 SQL Auth Configuration
# Included by 10-auth.conf
# sql_driver + mysql block live in dovecot.conf — not here.
# ============================================================

passdb sql {
  # BLF-CRYPT = bcrypt. Passwords must be stored as
  # {BLF-CRYPT}$2y$... or the scheme prefix embedded in the hash.
  default_password_scheme = BLF-CRYPT

  # Returns 'password' field — that is all passdb needs.
  # active = 1 guards deactivated accounts.
  query = SELECT password \
          FROM mailbox \
          WHERE username = '%{user}' \
            AND active = 1
}

userdb sql {
  # home   — parent of Maildir/ and sieve/; must match NFS layout
  # uid/gid — vmail system user numeric IDs
  # quota_storage_size — per-user limit fed to the 'count' quota driver;
  #   format is bytes (integer). Dovecot accepts raw bytes here.
  #   If quota = 0 we return NULL so Dovecot treats it as unlimited.
  query = SELECT \
            CONCAT('/var/vmail/', domain, '/', local_part) AS home, \
            {{ vmail_uid }} AS uid, \
            {{ vmail_gid }} AS gid, \
            NULLIF(quota, 0) AS quota_storage_size \
          FROM mailbox \
          WHERE username = '%{user}' \
            AND active = 1

  # Used by doveadm -A and quota recalculation
  iterate_query = SELECT username FROM mailbox WHERE active = 1
}
